# Docker Compose 环境配置文件
# 复制此文件为 .env 后修改相应配置

#============= 基础配置 =============
# 项目名称
COMPOSE_PROJECT_NAME=wemeeting

#============= MySQL 配置 =============
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=wemeeting

#============= 消息队列配置 =============
# 选择消息中间件类型：redis 或 rabbitmq
# 后端会根据此配置选择使用 Redis 或 RabbitMQ 进行消息分发
MESSAGE_CHANNEL=redis

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ 配置
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin